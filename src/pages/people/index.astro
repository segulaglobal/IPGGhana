---
import MainLayout from "../../layouts/MainLayout.astro";
import wisdomImage from "../../assets/IMG_0152.JPG.jpeg";
import { Image } from "astro:assets";

// Sanity client + image URL builder
import { sanityClient } from "sanity:client";
import imageUrlBuilder from "@sanity/image-url";
import type { SanityDocument } from "@sanity/client";

// Set up the image URL builder
const urlFor = (source: any) =>
  source?.asset?._ref ? imageUrlBuilder(sanityClient).image(source).auto("format").fit("max").url() : null;

// Query people documents from Sanity (excluding the specified fellows)
const PEOPLE_QUERY = `*[_type == "people" && defined(slug.current) && !(slug.current in ["prof-isaac-boadi", "dr-frank-bannor", "dr-kwaku-agyeman-budu"])] | order(_createdAt desc){
  _id,
  name,
  slug,
  role,
  institution,
  expertise,
  image
}`;

const sanityPeople: SanityDocument[] = await sanityClient.fetch(PEOPLE_QUERY);

const wisdomEdemGomashie = {
  _id: "wisdom-edem-gomashie",
  name: "Ing. Wisdom Edem Gomashie",
  slug: { current: "ing-wisdom-edem-gomashie" },
  role: "Mining Engineer | Policy Analyst | Natural Resource Governance Specialist",
  institution: "African Policy Lens",
  expertise: "Mineral resource governance, mining policy reform, local content development, and sustainable mining practices in Africa",
  image: wisdomImage,
  email: "Wissfarad@gmail.com",
  linkedin: "https://www.linkedin.com/in/ing-wisdom-edem-gomashie-ma-msc-bsc-mwaimm-pe-ghie-73bab3109?utm_source=share_via&utm_content=profile&utm_medium=member_ios"
};

const people = [...sanityPeople, wisdomEdemGomashie];
---

<MainLayout title="People" description="Meet the distinguished team at Africa Policy Lens.">
  <!-- Hero Section -->
  <section class="section-hero pt-20 md:pt-8">
    <div class="container wrapper">
      <div class="h-full flex flex-col text-center items-center justify-center">
        <h1 class="my-5 text-4xl font-extrabold tracking-tight leading-none text-white md:text-5xl lg:text-6xl animate__animated animate__fadeInUp">
          Meet the Team
        </h1>
        <p class="mb-8 text-lg font-normal text-gray-200 lg:text-xl sm:px-16 xl:px-48 animate__animated animate__fadeInUp">
          Africa Policy Lens is led by a team of distinguished fellows from academia and various professional fields, each contributing expertise in governance, policy analysis, economics, law, and public sector development.
        </p>
      </div>
    </div>
  </section>

  <!-- People Grid -->
  <section class="py-36" id="fellows">
    <div class="container wrapper">
      <h2 class="mb-16 text-4xl tracking-tight font-extrabold text-gray-900 text-center animate__animated animate__fadeInUp">
        Our Fellows
      </h2>
      <div class="grid grid-cols-1 gap-8 md:grid-cols-2 lg:grid-cols-3 animate__animated animate__fadeInUp">
        {people.map((person) => (
          <a
            href={`/people/${person.slug.current}`}
            class="group people bg-white shadow-md rounded-xl overflow-hidden transform transition hover:-translate-y-1 hover:shadow-xl"
          >
            <div class="w-full h-96 overflow-hidden">
              {person._id === "wisdom-edem-gomashie" ? (
                <Image
                  src={person.image}
                  alt={person.name}
                  width={600}
                  height={800}
                  class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
                />
              ) : (
                <img
                  src={urlFor(person.image) ?? "/fallback.jpg"}
                  alt={person.name}
                  class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
                />
              )}
            </div>
            <div class="p-4">
              <div class="people-text">
                <h3 class="text-2xl font-bold">{person.name}</h3>
                <p class="text-gray-600 mb-4">{person.role}</p>
                <p class="text-sm text-gray-500 mb-2">{person.institution}</p>
              </div>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>
</MainLayout>

<style>
  .section-hero {
    width: 100%;
    height: 50vh;
    background-color: var(--clr-black);
    background-size: cover;
    background-position: top;
  }

  .people {
    text-align: center;
    width: 100%;
    transition: 0.3s;
  }

  .people-text {
    margin-top: 1rem;
  }

  .people-text h3 {
    font-weight: bold;
    font-size: 1.25rem;
  }

  .people-text p {
    color: #606060;
  }
</style>
